# -----------------------------------------------------------------------------
# TokenToast – root .gitignore (monorepo: Node, Next.js, Python/FastAPI)
# -----------------------------------------------------------------------------

# ---- Dependencies ----
node_modules/
.pnpm-store/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Python ----
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
*.manifest
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
*.cover
.hypothesis/

# ---- Next.js (web) ----
.next/
out/
.vercel
*.tsbuildinfo
next-env.d.ts

# ---- Turbo ----
.turbo/

# ---- Environment and secrets (never commit) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# ---- IDE and editors ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ---- OS ----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ---- Logs and debug ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# ---- Build and output ----
/build
/dist
*.local

# ---- Misc ----
*.pem
.cache/

# If these were already committed, remove from index (keeps files on disk):
#   git rm -r --cached node_modules .next .venv __pycache__ .pytest_cache .turbo 2>/dev/null; git commit -m "chore: stop tracking ignored paths"
